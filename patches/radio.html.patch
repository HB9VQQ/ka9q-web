+<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
+<style>
+/* ───────────────────────────────────────────
+   RESET + DESIGN TOKENS
+─────────────────────────────────────────── */
+*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
+
+:root {
+  /* Palette */
+  --ink:       #060b12;
+  --ink2:      #0a1220;
+  --ink3:      #0e1928;
+  --panel:     #091422;
+  --rule:      #152235;
+  --rule2:     #1c2f47;
+  --teal:      #00d4c8;
+  --teal-dim:  #007a74;
+  --teal-glow: rgba(0,212,200,0.15);
+  --amber:     #f5a623;
+  --amber-dim: #a06a0a;
+  --coral:     #ff5f57;
+  --coral-dim: #7a1f1a;
+  --lime:      #7fff6e;
+  --lime-dim:  #3a7a30;
+  --violet:    #c084fc;
+  --txt:       #b8cfe0;
+  --txt-dim:   #4a6a84;
+  --txt-hi:    #e0f0ff;
+  --white:     #f0f8ff;
+
+  /* Typography */
+  --f-ui:   'Chakra Petch', sans-serif;
+  --f-mono: 'JetBrains Mono', monospace;
+
+  /* Sizes */
+  --hdr-h:   32px;
+  --freq-h:  54px;
+  --ctrl-h:  82px;
+  --dx-h:    48px;
+  --stat-h:  30px;
+}
+
+html,body{height:100%;background:var(--ink);color:var(--txt);font-family:var(--f-ui);font-size:12px;overflow:hidden}
+
+/* Scanline texture overlay */
+body::before {
+  content:''; position:fixed; inset:0; pointer-events:none; z-index:9999;
+  background:repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.04) 2px, rgba(0,0,0,0.04) 4px);
+}
+
+::-webkit-scrollbar{width:4px;height:4px}
+::-webkit-scrollbar-track{background:var(--ink2)}
+::-webkit-scrollbar-thumb{background:var(--rule2);border-radius:2px}
+
+/* ───────────────────────────────────────────
+   LAYOUT SHELL
+─────────────────────────────────────────── */
+#app {
+  display:flex; flex-direction:column;
+  height:100vh; width:100vw; overflow:hidden;
+}
+
+/* ───────────────────────────────────────────
+   HEADER
+─────────────────────────────────────────── */
+#hdr {
+  background:var(--ink2);
+  border-bottom:1px solid var(--rule);
+  display:flex; align-items:center; gap:0;
+  padding:0 12px; flex-shrink:0; overflow:hidden;
+}
+
+/* Solar pills */.solar-row {
+  display:flex; align-items:center; gap:6px;
+  padding:0 14px; border-right:1px solid var(--rule); flex-shrink:0;
+}
+.sol-pill {
+  display:flex; align-items:center; gap:4px;
+  background:var(--ink3); border:1px solid var(--rule2);
+  border-radius:3px; padding:1px 7px;
+  font-family:var(--f-mono); font-size:10px;
+}
+.sol-pill .lbl { color:var(--txt-dim); letter-spacing:0.08em }
+.sol-pill .val { color:var(--teal); font-weight:500 }
+.sol-pill .val.ok   { color:var(--lime) }
+.sol-pill .val.warn { color:var(--amber) }
+.sol-pill .val.bad  { color:var(--coral) }
+
+/* UTC clock */
+#clock {
+  margin-left:auto;
+  font-family:var(--f-mono); font-size:12px; font-weight:500;
+  color:var(--teal-dim); letter-spacing:0.08em; flex-shrink:0;
+}
+
+/* ───────────────────────────────────────────
+   WATERFALL + SPECTRUM CANVAS AREA
+─────────────────────────────────────────── */
+#wf-wrap {
+  position:relative; background:#000;
+  border-bottom:none; overflow:hidden;
+  flex-shrink:0;
+  /* initial height set by JS */
+  height:420px;
+}
+#wf-wrap canvas { position:absolute; top:0; left:0; width:100%; height:100% }
+#dx-overlay { pointer-events:none; z-index:3 }
+
+/* Internal spectrum/waterfall split handle */
+#spec-resizer {
+  position:absolute; left:0; right:0; height:5px;
+  cursor:ns-resize; z-index:5;
+  display:flex; align-items:center; justify-content:center;
+  transition:background .15s;
+}
+#spec-resizer:hover, #spec-resizer.dragging {
+  background:rgba(0,212,200,0.18);
+}
+#spec-resizer::after {
+  content:''; display:block;
+  width:48px; height:2px; border-radius:1px;
+  background:rgba(0,212,200,0.3);
+  transition:background .15s;
+}
+#spec-resizer:hover::after, #spec-resizer.dragging::after {
+  background:var(--teal);
+  box-shadow:0 0 6px var(--teal);
+}
+/* Resize handle — outer (between wf-wrap and freq strip) */
+#wf-resizer {
+  height:5px; background:var(--rule); cursor:ns-resize; flex-shrink:0;
+  position:relative; z-index:20; transition:background .15s;
+  display:flex; align-items:center; justify-content:center;
+}
+#wf-resizer:hover, #wf-resizer.dragging { background:var(--teal-dim); }
+#wf-resizer::after {
+  content:''; display:block;
+  width:36px; height:2px; border-radius:1px;
+  background:rgba(0,212,200,0.35);
+  transition:background .15s;
+}
+#wf-resizer:hover::after, #wf-resizer.dragging::after { background:var(--teal); }
+
+/* ───────────────────────────────────────────
+   FREQUENCY STRIP
+─────────────────────────────────────────── */
+#freq-strip {
+  background:var(--ink2); border-bottom:1px solid var(--rule);
+  display:flex; align-items:center; padding:0 10px; gap:0; overflow:hidden;
+}
+
+/* Main freq display */
+.freq-block {
+  display:flex; align-items:baseline; gap:5px;
+  padding-right:14px; border-right:1px solid var(--rule);
+  flex-shrink:0; position:relative;
+}
+#freq {
+  font-family:var(--f-ui); font-size:30px; font-weight:700;
+  color:var(--teal); background:transparent; border:none; outline:none;
+  width:168px; letter-spacing:0.04em; line-height:1;
+  caret-color:var(--teal);
+  text-shadow:0 0 20px rgba(0,212,200,0.4);
+}
+#freq:focus { text-shadow:0 0 24px rgba(0,212,200,0.7) }
+.freq-unit {
+  font-family:var(--f-ui); font-size:11px; font-weight:500; letter-spacing:0.1em;
+  color:var(--teal-dim); align-self:flex-end; padding-bottom:4px;
+}
+
+/* VFO label */
+.vfo-lbl {
+  position:absolute; top:3px; left:0;
+  font-family:var(--f-mono); font-size:8px; color:var(--txt-dim); letter-spacing:0.15em;
+}
+
+/* Nudge + SET */
+.nudge-group {
+  display:flex; align-items:center; gap:2px; padding:0 12px;
+  border-right:1px solid var(--rule); flex-shrink:0;
+}
+.nbtn {
+  background:var(--ink3); border:1px solid var(--rule2); color:var(--txt);
+  font-family:var(--f-mono); font-size:11px; padding:3px 8px;
+  border-radius:2px; cursor:pointer; line-height:1; transition:all .1s;
+}
+.nbtn:hover { background:var(--rule2); color:var(--txt-hi) }
+.nbtn.set-btn {
+  border-color:var(--teal-dim); color:var(--teal); background:rgba(0,212,200,0.06);
+  padding:3px 12px; font-weight:500; letter-spacing:0.06em;
+}
+.nbtn.set-btn:hover { background:rgba(0,212,200,0.14); box-shadow:0 0 8px var(--teal-glow) }
+
+/* Strip section */
+.fs {
+  display:flex; align-items:center; gap:6px;
+  padding:0 12px; border-right:1px solid var(--rule); flex-shrink:0;
+}
+.fs:last-child { border-right:none }
+
+.lbl {
+  font-family:var(--f-ui); font-size:9px; font-weight:500; color:var(--txt-dim);
+  letter-spacing:0.12em; text-transform:uppercase; white-space:nowrap;
+}
+
+.sel {
+  background:var(--ink3); border:1px solid var(--rule2); color:var(--txt);
+  font-family:var(--f-mono); font-size:11px; padding:2px 5px;
+  border-radius:2px; outline:none; cursor:pointer;
+}
+.sel:focus { border-color:var(--teal-dim) }
+.sel option { background:var(--ink2) }
+.sel optgroup { color:var(--txt-dim) }
+
+.num-inp {
+  background:var(--ink3); border:1px solid var(--rule2); color:var(--teal);
+  font-family:var(--f-mono); font-size:11px; padding:2px 5px; text-align:right;
+  border-radius:2px; outline:none; width:56px;
+}
+.num-inp:focus { border-color:var(--teal-dim) }
+
+/* S-meter section */
+.smeter-section {
+  margin-left:auto; display:flex; align-items:center; gap:10px; flex-shrink:0;
+  padding-left:14px; border-left:1px solid var(--rule);
+}
+.sm-val { font-family:var(--f-mono); font-size:13px; font-weight:500; color:var(--teal); min-width:24px }
+.sm-dbm { font-family:var(--f-mono); font-size:10px; color:var(--txt-dim) }
+
+/* ───────────────────────────────────────────
+   CONTROLS STRIP
+─────────────────────────────────────────── */
+#ctrl-strip {
+  background:var(--ink3); border-bottom:1px solid var(--rule);
+  display:flex; align-items:stretch; padding:0; overflow-x:auto; flex-shrink:0;
+}
+
+.cg { /* control group */
+  display:flex; flex-direction:column; justify-content:center; gap:5px;
+  padding:6px 12px; border-right:1px solid var(--rule); flex-shrink:0;
+}
+.cg:last-child { border-right:none }
+.cg-title {
+  font-family:var(--f-ui); font-size:8px; font-weight:600; letter-spacing:0.16em;
+  text-transform:uppercase; color:var(--txt-dim); margin-bottom:1px;
+}
+.crow { display:flex; align-items:center; gap:5px }
+
+input[type=range] {
+  -webkit-appearance:none; height:3px; border-radius:2px;
+  background:var(--rule2); outline:none; cursor:pointer;
+}
+input[type=range]::-webkit-slider-thumb {
+  -webkit-appearance:none; width:10px; height:10px; border-radius:50%;
+  background:var(--teal); border:1px solid var(--ink); cursor:pointer;
+}
+
+.cbtn {
+  background:var(--ink2); border:1px solid var(--rule2); color:var(--txt);
+  font-family:var(--f-ui); font-size:10px; font-weight:500; letter-spacing:0.04em;
+  padding:3px 9px; border-radius:2px; cursor:pointer; transition:all .1s; white-space:nowrap;
+}
+.cbtn:hover { background:var(--rule2); color:var(--txt-hi) }
+.cbtn.on    { background:rgba(0,212,200,0.1); border-color:var(--teal-dim); color:var(--teal) }
+.cbtn.go    { background:rgba(127,255,110,0.08); border-color:var(--lime-dim); color:var(--lime) }
+.cbtn.go:hover { background:rgba(127,255,110,0.14) }
+.cbtn.warn  { background:rgba(255,95,87,0.08); border-color:var(--coral-dim); color:var(--coral) }
+.cbtn.purple{ background:rgba(192,132,252,0.08); border-color:#6a3a9a; color:var(--violet) }
+
+.ck {
+  display:flex; align-items:center; gap:4px; cursor:pointer;
+  font-family:var(--f-mono); font-size:10px; color:var(--txt); user-select:none;
+}
+.ck input { accent-color:var(--teal); width:10px; height:10px; cursor:pointer }
+
+/* ───────────────────────────────────────────
+   DX CLUSTER STRIP
+─────────────────────────────────────────── */
+#dx-strip {
+  background:var(--panel); border-bottom:1px solid var(--rule);
+  display:flex; align-items:center; padding:0; overflow-x:auto; flex-shrink:0;
+  /* subtle left accent */
+  border-left:3px solid var(--teal-dim);
+}
+
+.dxg {
+  display:flex; align-items:center; gap:7px;
+  padding:0 12px; border-right:1px solid var(--rule); flex-shrink:0; height:100%;
+}
+.dxg:last-child { border-right:none }
+.dxg-lbl {
+  font-family:var(--f-ui); font-size:8px; font-weight:600; letter-spacing:0.16em;
+  text-transform:uppercase; color:var(--teal-dim); white-space:nowrap;
+}
+
+/* Toggle */
+.dx-toggle {
+  display:flex; align-items:center; gap:6px;
+  background:rgba(0,212,200,0.06); border:1px solid var(--teal-dim);
+  border-radius:3px; padding:3px 10px; cursor:pointer; transition:all .15s;
+  font-family:var(--f-ui); font-size:10px; font-weight:600; letter-spacing:0.08em; color:var(--teal);
+}
+.dx-toggle:hover { background:rgba(0,212,200,0.12) }
+.dx-toggle.off { background:var(--ink3); border-color:var(--rule2); color:var(--txt-dim) }
+
+/* Status dot */
+.dot {
+  width:7px; height:7px; border-radius:50%;
+  background:var(--lime); box-shadow:0 0 6px var(--lime); animation:blink 2s infinite;
+}
+.dot.connecting { background:var(--amber); box-shadow:0 0 6px var(--amber) }
+.dot.off        { background:var(--rule2); box-shadow:none; animation:none }
+
+/* Spot count badge */
+.spot-badge {
+  font-family:var(--f-mono); font-size:11px; font-weight:500;
+  color:var(--teal); background:rgba(0,212,200,0.1);
+  border:1px solid rgba(0,212,200,0.25); border-radius:2px;
+  padding:1px 7px; min-width:28px; text-align:center;
+}
+
+/* Cluster select */
+.cluster-sel {
+  background:var(--ink2); border:1px solid var(--rule2); color:var(--txt);
+  font-family:var(--f-mono); font-size:10px; padding:2px 6px; border-radius:2px;
+  outline:none; max-width:205px; cursor:pointer;
+}
+.cluster-sel:focus { border-color:var(--teal-dim) }
+.cluster-sel option { background:var(--ink2) }
+
+.icon-btn {
+  background:var(--ink2); border:1px solid var(--rule2); color:var(--txt-dim);
+  font-size:12px; padding:2px 7px; border-radius:2px; cursor:pointer; line-height:1; transition:all .1s;
+}
+.icon-btn:hover { color:var(--teal); border-color:var(--teal-dim) }
+
+/* Callsign */
+.call-inp {
+  background:var(--ink2); border:1px solid var(--rule2); color:var(--lime);
+  font-family:var(--f-mono); font-size:11px; font-weight:500;
+  padding:2px 7px; border-radius:2px; outline:none; width:85px; letter-spacing:0.06em;
+  text-transform:uppercase;
+}
+.call-inp:focus { border-color:var(--lime-dim); box-shadow:0 0 8px rgba(127,255,110,0.1) }
+
+/* Mode legend */
+.legend { display:flex; gap:7px; align-items:center }
+.leg {
+  display:flex; align-items:center; gap:3px;
+  font-family:var(--f-mono); font-size:9px; color:var(--txt-dim); cursor:pointer; transition:color .1s;
+}
+.leg:hover,.leg.on { color:var(--txt-hi) }
+.leg-sq { width:8px; height:8px; border-radius:1px; flex-shrink:0; opacity:0.85 }
+
+/* Bridge URL */
+.bridge-inp {
+  background:var(--ink2); border:1px solid var(--rule2); color:var(--teal-dim);
+  font-family:var(--f-mono); font-size:9px; padding:2px 6px; border-radius:2px;
+  outline:none; width:170px;
+}
+.bridge-inp:focus { border-color:var(--teal-dim) }
+
+/* ───────────────────────────────────────────
+   STATUS BAR
+─────────────────────────────────────────── */
+#stat-bar {
+  background:var(--ink2); border-top:none;
+  display:flex; align-items:center; overflow:hidden;
+  font-family:var(--f-mono); font-size:9px; flex-shrink:0;
+}
+.si {
+  display:flex; align-items:center; gap:4px;
+  padding:0 10px; border-right:1px solid var(--rule); height:100%; flex-shrink:0;
+}
+.si-lbl { color:var(--txt-dim); letter-spacing:0.08em; text-transform:uppercase }
+.si-val { color:var(--txt); }
+.si-val.hi { color:var(--teal) }
+.si-val.warn { color:var(--amber) }
+.si-val.ok { color:var(--lime) }
+
+/* WWV tail */
+.wwv-tail {
+  margin-left:auto; padding:0 10px; color:var(--txt-dim); font-size:9px;
+  white-space:nowrap; border-left:1px solid var(--rule);
+}
+.wwv-tail a { color:inherit; text-decoration:none }
+.wwv-tail a:hover { color:var(--teal) }
+
+/* From upstream style.css — required for Options dialog and overlay */
+#optionsDialog { display:none; position:absolute; width:auto; max-width:600px; padding:10px; background:#0d1b2a; border:1px solid #00d4c8; box-shadow:0 4px 24px rgba(0,0,0,0.8); z-index:1000; font-size:12px; color:#c8d8e8; border-radius:4px; }
+#optionsDialog input[type=text], #optionsDialog input[type=number], #optionsDialog select { background:#1a2a3a; color:#c8d8e8; border:1px solid #2a4a6a; padding:2px 4px; border-radius:2px; }
+#optionsDialog input[type=checkbox] { accent-color:#00d4c8; }
+#optionsDialog button { background:#1a2a3a; color:#c8d8e8; border:1px solid #2a4a6a; padding:3px 8px; cursor:pointer; border-radius:2px; white-space:nowrap; }
+#optionsDialog button:hover { background:#2a3a4a; border-color:#00d4c8; }
+#optionsDialog label { color:#c8d8e8; }
+#optionsDialog.open { display:block; }
+#dialogOverlay { display:none; position:fixed; left:0; top:0; width:100%; height:100%; z-index:500; pointer-events:none; }
+#dialogOverlay.open { display:block; }
+  @keyframes rec-flash { 0%,100%{opacity:1} 50%{opacity:0.2} }
+  .recording { animation: rec-flash 1s ease-in-out infinite; color:#ff4444 !important; border-color:#ff4444 !important; }
+</style>
 </head>

+    const rl = R - 24;
+    const isOver = m.t.startsWith('+') && mode === 0;
+    ctx.fillStyle = isOver ? '#ff8844' : '#4a8aaa';
+    ctx.font = `bold ${m.t.length > 2 ? 8 : 9}px "JetBrains Mono"`;
